# Environment variables for reference data extraction scripts.
# Copy to .env and fill in actual values on the node host.
# NEVER commit the .env file — it is gitignored.

ADE_NODE_SOCKET_PATH=/path/to/node.socket
ADE_CARDANO_CLI=/path/to/cardano-cli
ADE_IMMUTABLEDB_PATH=/path/to/immutable
ADE_LEDGERDB_PATH=/path/to/ledger
ADE_CARDANO_NODE_VERSION=10.6.2
ADE_CARDANO_NODE_GIT_REV=0d697f14
